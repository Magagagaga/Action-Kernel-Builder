#!/bin/sh

set -e -x

# Kernel Source
KERNEL_SOURCE="https://github.com/LineageOS/android_kernel_xiaomi_vayu"
KERNEL_DEFCONFIG="vayu_defconfig"

# Prebuilt Clang Toolchain (AOSP)
CLANG_URL="https://android.googlesource.com/platform/prebuilts/clang/host/linux-x86/+archive/refs/heads/master-kernel-build-2021/clang-r416183b.tar.gz"

# Prebuilt GCC Utilities (AOSP)
GCC_x64="https://android.googlesource.com/platform/prebuilts/gcc/linux-x86/aarch64/aarch64-linux-android-4.9"
GCC_x32="https://android.googlesource.com/platform/prebuilts/gcc/linux-x86/arm/arm-linux-androideabi-4.9"
GCC_BRANCH="master-kernel-build-2021"

# Setup make Command
make_fun() {
	make O=out ARCH=arm64 CC=clang HOSTCC=clang DTC=dtc \
		CLANG_TRIPLE=aarch64-linux-gnu- \
		CROSS_COMPILE=aarch64-linux-androidkernel- "$@"
}

# Work Path
WORK="${HOME}/work"
KERNEL="myKernel"
KERNEL_SRC="${WORK}/${KERNEL}"

# Prepare Directory
mkdir -p "${WORK}"
cd "${WORK}" || exit 1

# Cloning all the Necessary files
if [ ! -d clang ]; then mkdir clang && curl -Lsq "${CLANG_URL}" -o clang.tgz && tar -xzf clang.tgz -C clang; fi
[ ! -d x64 ] && git clone --depth=1 "${GCC_x64}" -b "${GCC_BRANCH}" ./x64
[ ! -d x32 ] && git clone --depth=1 "${GCC_x32}" -b "${GCC_BRANCH}" ./x32
[ ! -d "${KERNEL}" ] && git clone --depth=1 "${KERNEL_SOURCE}" "${KERNEL}"

# Setting Toolchain Path
PATH="${WORK}/clang/bin:${WORK}/x64/bin:${WORK}/x32/bin:/bin"

# Enter Kernel root directory
cd "${KERNEL_SRC}" || exit 1

# --- АВТОПОИСК И ПРАВКА КОНФИГА ---
# Ищем vayu_defconfig во всех подпапках arch/arm64/configs
REAL_CONF_PATH=$(find arch/arm64/configs -name "vayu_defconfig" | head -n 1)

if [ -n "$REAL_CONF_PATH" ]; then
    echo "Нашёл конфиг по пути: $REAL_CONF_PATH"
    # Добавляем твои настройки для Wi-Fi адаптера
    sed -i 's/# CONFIG_RT2800USB is not set/CONFIG_RT2800USB=y/g' "$REAL_CONF_PATH"
    echo "CONFIG_RT2X00=y" >> "$REAL_CONF_PATH"
    echo "CONFIG_RT2800USB_RT53XX=y" >> "$REAL_CONF_PATH"
    echo "CONFIG_RT2800USB_UNKNOWN=y" >> "$REAL_CONF_PATH"
    echo "CONFIG_NL80211_TESTMODE=y" >> "$REAL_CONF_PATH"
    
    # Получаем чистое имя для команды make (убираем путь до configs/)
    MAKE_CONF=$(echo "$REAL_CONF_PATH" | sed 's|arch/arm64/configs/||')
    
    # Старт компиляции
    make_fun "$MAKE_CONF"
    make_fun -j"$(nproc --all)" 2>&1 | tee build.log
else
    echo "ОШИБКА: vayu_defconfig не найден вообще!"
    find arch/arm64/configs -maxdepth 3
    exit 1
fi
